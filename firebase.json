{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "packages/dashboard/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "relay-api",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/auth/**",
        "run": {
          "serviceId": "relay-api",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/unsubscribe/**",
        "run": {
          "serviceId": "relay-api",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
